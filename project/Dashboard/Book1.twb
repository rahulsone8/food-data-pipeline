      <column caption='Action1' datatype='string' name='[Action]' role='dimension' type='nominal' />
      <column caption='Conversion %' datatype='real' default-format='p0.0%' name='[Calculation_0896222528794624]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Calculation_0896222592270338]) / WINDOW_MAX(COUNTD([Calculation_0896222592270338]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='User ID' datatype='string' name='[Calculation_0896222592270338]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF NOT ISNULL([customer_contact]) THEN [customer_contact]&#10;ELSEIF NOT ISNULL([Shop ID]) THEN STR([Shop ID])&#10;ELSE &quot;MISSING&quot; &#10;END' />
      </column>
      <column caption='Conversion Rate' datatype='real' default-format='p0.0%' name='[Calculation_0896222623227907]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#10;IF [Action] = &apos;ORDER&apos; THEN [Calculation_0896222592270338] END&#10;)&#10;/&#10;COUNTD(&#10;IF [Action] = &apos;VIEW_CART&apos; THEN [Calculation_0896222592270338] END&#10;)' />
      </column>
